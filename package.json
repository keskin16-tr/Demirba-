{
  "name": "nlabel-app",
  "version": "2.0.0",
  "description": "NLabel - Brother P900W Etiket Yazdırma Sistemi",
  "main": "server.js",
  "bin": "server.js",
  "private": true,

  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "build": "pkg . --out-path dist",
    "clean": "rimraf dist"
  },

  "dependencies": {
    "csvtojson": "^2.0.10",
    "exceljs": "^4.4.0",
    "express": "^5.1.0",
    "express-session": "^1.18.2",
    "iconv-lite": "^0.7.0",
    "multer": "^2.0.2",
    "nunjucks": "^3.2.4",
    "qrcode": "^1.5.4",
    "xlsx": "^0.18.5"
  },

  "devDependencies": {
    "pkg": "^5.8.1",
    "rimraf": "^6.0.1"
  },

  "pkg": {
    "targets": [
      "node20-win-x64"
    ],
    "outputPath": "dist",
    "assets": [
      "views/**/*",
      "public/**/*",
      "users.json",
      "templates/**/*",
      "labels/**/*"
    ]
  },

  "engines": {
    "node": ">=20.0.0"
  },

  "keywords": [
    "label",
    "barcode",
    "brother",
    "pt-p900w",
    "inventory"
  ],

  "author": "Huseyin Keskin",
  "license": "MIT"
}
